# Frontend + Supabase project contract for this repo.
# Copy this file to .env.local and fill the values for the correct project.

SUPABASE_PROJECT_REF=your_project_ref
VITE_SUPABASE_URL=https://your_project_ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Name of the environment variable that stores the access token for the
# account that owns the correct Supabase project. Do not put the token value
# in .env.local.
SUPABASE_ACCESS_TOKEN_ENV=SUPABASE_ACCESS_TOKEN_PRODFORGE
