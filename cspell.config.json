{
  "$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/cspell.schema.json",
  "version": "0.2",
  "language": "pt-BR,en",
  "caseSensitive": true,
  "import": ["@cspell/dict-pt-br/cspell-ext.json"],
  "dictionaryDefinitions": [
    {
      "name": "prodforge-terms",
      "path": "./cspell-project-words.txt",
      "addWords": true
    }
  ],
  "dictionaries": ["pt-br", "prodforge-terms"],
  "ignorePaths": [
    "node_modules/**",
    "dist/**",
    "dist-ssr/**",
    "artifacts/**",
    "temp/**",
    "docs/**",
    "package-lock.json"
  ],
  "patterns": [
    {
      "name": "copy-source-marker",
      "pattern": "^@@.*$"
    }
  ],
  "ignoreRegExpList": ["copy-source-marker"],
  "flagWords": [
    "voce:você",
    "voces:vocês",
    "nao:não",
    "agil:ágil",
    "area:área",
    "gratis:grátis",
    "pratico:prático",
    "pratica:prática",
    "criterio:critério",
    "criterios:critérios",
